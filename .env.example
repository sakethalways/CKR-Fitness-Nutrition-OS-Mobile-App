# Copy this file to `.env` (at the project root) and fill in the values from
# your Supabase project Settings → API page.
#
# The EXPO_PUBLIC_ prefix is required — Expo only exposes env vars with that
# prefix to client code.

EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-public-key...

# DO NOT put the service role key here. It stays server-side only,
# automatically injected into Edge Functions as SUPABASE_SERVICE_ROLE_KEY.
