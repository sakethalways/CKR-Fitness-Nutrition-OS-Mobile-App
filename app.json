{
  "expo": {
    "name": "CKR Nutrition OS",
    "slug": "ckr-nutrition-os",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "ckrnutrition",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ckrfitness.nutritionos",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "UIBackgroundModes": []
      }
    },
    "android": {
      "package": "com.ckrfitness.nutritionos",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0B0D"
      },
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0B0D",
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C6F432"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "9b6ece7b-c030-4e78-a8fb-e4e2e3cc749c"
      },
      "router": {}
    },
    "owner": "chandrackr",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9b6ece7b-c030-4e78-a8fb-e4e2e3cc749c"
    }
  }
}
